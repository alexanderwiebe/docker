{
  "title": "Errors & Warnings",
  "uid": "errors-overview",
  "tags": ["errors", "logs"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(job)",
        "label": "Job",
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Rate (logs/sec)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (job) (rate({job=~\"$job\"} |~ \"(?i)(error|exception|fatal|critical)\" [5m]))",
          "legendFormat": "errors — {{job}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (job) (rate({job=~\"$job\"} |~ \"(?i)(warn|warning)\" [5m]))",
          "legendFormat": "warnings — {{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Count (last interval)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=~\"$job\"} |~ \"(?i)(error|exception|fatal|critical)\" [$__range]))",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "Warning Count (last interval)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 7, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=~\"$job\"} |~ \"(?i)(warn|warning)\" [$__range]))",
          "legendFormat": "Warnings"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Usage %",
      "type": "stat",
      "gridPos": { "x": 12, "y": 7, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory Usage %",
      "type": "stat",
      "gridPos": { "x": 18, "y": 7, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory"
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent Error Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=~\"$job\"} |~ \"(?i)(error|exception|fatal|critical)\"",
          "legendFormat": ""
        }
      ]
    }
  ]
}
